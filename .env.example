# Copy to `.env`, fill in values, restart `npm run dev`.
# Never commit real keys — use placeholders here only.

# TEIKOS web app — used by “Get Started Free”, pricing CTAs, “Try Agent Lab”, and “Sign In” (full URLs)
# VITE_APP_SIGNUP_URL=https://app.teikos.io/signup
# VITE_APP_LOGIN_URL=https://app.teikos.io/login

# Optional: replace YOUR_PROJECT in docs playbooks with your Supabase tool-router base
# VITE_TOOL_ROUTER_BASE=https://YOUR_PROJECT.supabase.co/functions/v1/tool-router/tool
