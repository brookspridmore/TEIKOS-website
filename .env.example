# Copy to `.env`, fill in values, restart `npm run dev`.
# Never commit real keys — use placeholders here only.

# Required for the main pricing table
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICING_TABLE_ID=prctbl_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: second Pricing Table — typically 3 monthly products for ACTIVE AGENCY subscribers only.
# Configure eligibility in Stripe (e.g. Checkout rules, Customer Portal, or your app) so only
# paying Agency customers can complete purchase; the site only embeds the table + disclaimer.
VITE_STRIPE_PRICING_TABLE_ID_2=prctbl_1TN1AoRvCfD8nLytPGcQydW9

# TEIKOS web app — used by “Get Started Free”, “Try Agent Lab”, and “Sign In” CTAs (full URLs)
# VITE_APP_SIGNUP_URL=https://app.teikos.io/signup
# VITE_APP_LOGIN_URL=https://app.teikos.io/login
